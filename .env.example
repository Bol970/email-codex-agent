AGENTMAIL_API_KEY=am_your_key_here

# Optional. If omitted, the app lets you pick or create an inbox.
AGENTMAIL_INBOX_ID=

# Optional. Defaults to 5173.
PORT=5173

# Optional. Useful for tests and first-run UI exploration without credentials.
MOCK_MODE=0

# Optional. Defaults to the local HTTP proxy requested for this project.
AGENTMAIL_PROXY_URL=http://127.0.0.1:8118
